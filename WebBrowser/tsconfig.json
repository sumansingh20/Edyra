{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["./renderer/**/*.js", "./main.js", "./preload.js", "./utils/**/*.js", "./services/**/*.js"],
  "exclude": ["node_modules", "dist", "build"]
}





